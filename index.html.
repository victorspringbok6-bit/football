  <!-- JS Architecture Injection -->
  <script type="module">
    // =========================================================================
    // MODULE 1: STORAGE ENGINE (IndexedDB Core Persistence)
    // =========================================================================
    class StorageEngine {
      constructor() {
        this.dbName = 'FootballAnalyticsDB';
        this.db = null;
      }

      async init() {
        return new Promise((resolve, reject) => {
          const request = indexedDB.open(this.dbName, 1);
          request.onupgradeneeded = (e) => {
            const db = e.target.result;
            if (!db.objectStoreNames.contains('cache')) db.createObjectStore('cache', { keyPath: 'key' });
            if (!db.objectStoreNames.contains('audits')) db.createObjectStore('audits', { keyPath: 'fixtureId' });
            if (!db.objectStoreNames.contains('weights')) db.createObjectStore('weights', { keyPath: 'market' });
          };
          request.onsuccess = (e) => { this.db = e.target.result; resolve(); };
          request.onerror = (e) => reject(e);
        });
      }

      async getCache(key) {
        return new Promise((resolve) => {
          const tx = this.db.transaction('cache', 'readonly');
          const store = tx.objectStore('cache');
          const req = store.get(key);
          req.onsuccess = () => resolve(req.result ? req.result.value : null);
          req.onerror = () => resolve(null);
        });
      }

      async setCache(key, value, ttlMs) {
        return new Promise((resolve) => {
          const tx = this.db.transaction('cache', 'readwrite');
          const store = tx.objectStore('cache');
          store.put({ key, value, timestamp: Date.now(), ttl: ttlMs });
          tx.oncomplete = () => resolve();
        });
      }

      async saveAudit(auditRecord) {
        return new Promise((resolve) => {
          const tx = this.db.transaction('audits', 'readwrite');
          const store = tx.objectStore('audits');
          store.put(auditRecord);
          tx.oncomplete = () => resolve();
        });
      }

      async getAllAudits() {
        return new Promise((resolve) => {
          const tx = this.db.transaction('audits', 'readonly');
          const store = tx.objectStore('audits');
          const req = store.getAll();
          req.onsuccess = () => resolve(req.result || []);
          req.onerror = () => resolve([]);
        });
      }
    }

    // =========================================================================
    // MODULE 2: CACHE MANAGER
    // =========================================================================
    class CacheManager {
      constructor(storageEngine) {
        this.storage = storageEngine;
        this.defaultTTL = 12 * 60 * 60 * 1000; // 12 Hours
      }

      async getOrFetch(key, fetchFn, customTTL = this.defaultTTL) {
        const cached = await this.storage.getCache(key);
        if (cached && (Date.now() - cached.timestamp < cached.ttl)) {
          return cached.value;
        }
        const freshData = await fetchFn();
        if (freshData) {
          await this.storage.setCache(key, freshData, customTTL);
        }
        return freshData;
      }
    }

    // =========================================================================
    // MODULE 3: API ENGINE
    // =========================================================================
    class APIEngine {
      constructor() {
        this.apiKey = localStorage.getItem('api_football_key') || '';
      }

      setApiKey(key) {
        this.apiKey = key;
        localStorage.setItem('api_football_key', key);
      }

      async fetchFromAPI(endpoint) {
        if (!this.apiKey) throw new Error("API key is missing.");
        const res = await fetch(`https://v3.football.api-sports.io/${endpoint}`, {
          method: 'GET',
          headers: { 'x-apisports-key': this.apiKey }
        });
        
        const limit = res.headers.get('x-ratelimit-requests-limit');
        const remaining = res.headers.get('x-ratelimit-requests-remaining');
        if (limit && remaining) {
          document.getElementById('metricQuota').innerText = `${remaining} / ${limit}`;
        }

        const data = await res.json();
        return data.response || [];
      }
    }

    // =========================================================================
    // MODULE 4: DATA & FEATURE ENGINE
    // =========================================================================
    class DataEngine {
      constructor(apiEngine, cacheManager) {
        this.api = apiEngine;
        this.cache = cacheManager;
      }

      async buildHistoricalProfile(teamId) {
        return this.cache.getOrFetch(`team_profile_${teamId}`, async () => {
          const fixtures = await this.api.fetchFromAPI(`fixtures?team=${teamId}&last=5`);
          return this.processFixtures(fixtures, teamId);
        });
      }

      async buildH2HProfile(homeId, awayId) {
        return this.cache.getOrFetch(`h2h_profile_${homeId}_${awayId}`, async () => {
          const fixtures = await this.api.fetchFromAPI(`fixtures/headtohead?h2h=${homeId}-${awayId}`);
          return this.processFixtures(fixtures.slice(0, 5), null);
        });
      }

      processFixtures(fixtures, targetTeamId) {
        if (!fixtures || fixtures.length === 0) return this.emptyMetrics();

        let scored = 0, conceded = 0, o25 = 0, u15 = 0, btts = 0, fh = 0, sh = 0;
        let cleanSheets = 0, failedToScore = 0;

        fixtures.forEach(f => {
          const hG = f.goals.home ?? 0;
          const aG = f.goals.away ?? 0;
          const hFH = f.score?.halftime?.home ?? 0;
          const aFH = f.score?.halftime?.away ?? 0;

          const totalG = hG + aG;
          const totalFH = hFH + aFH;
          const totalSH = totalG - totalFH;

          const isHome = targetTeamId ? f.teams.home.id === targetTeamId : true;
          const teamG = isHome ? hG : aG;
          const oppG = isHome ? aG : hG;

          scored += teamG;
          conceded += oppG;

          if (totalG >= 3) o25++;
          if (totalG <= 1) u15++;
          if (hG > 0 && aG > 0) btts++;
          if (totalFH >= 1) fh++;
          if (totalSH >= 1) sh++;
          if (oppG === 0) cleanSheets++;
          if (teamG === 0) failedToScore++;
        });

        const len = fixtures.length;
        return {
          avgScored: scored / len,
          avgConceded: conceded / len,
          o25Pct: o25 / len,
          u15Pct: u15 / len,
          bttsPct: btts / len,
          fhPct: fh / len,
          shPct: sh / len,
          cleanSheetPct: cleanSheets / len,
          failedToScorePct: failedToScore / len
        };
      }

      emptyMetrics() {
        return { avgScored: 0, avgConceded: 0, o25Pct: 0, u15Pct: 0, bttsPct: 0, fhPct: 0, shPct: 0, cleanSheetPct: 0, failedToScorePct: 0 };
      }
    }

    // =========================================================================
    // MODULE 5: MACHINE LEARNING WEIGHT ENGINE
    // =========================================================================
    class MLEngine {
      constructor() {
        this.weights = {
          O25: { bias: -1.8, avgScored: 0.85, avgConceded: 0.75, o25Pct: 1.80, cleanSheetPct: -0.90, failedToScorePct: -0.85, h2hO25Pct: 1.20 },
          BTTS: { bias: -1.5, bttsPct: 2.10, cleanSheetPct: -1.30, failedToScorePct: -1.25, h2hBttsPct: 1.10 },
          FH05: { bias: -1.1, fhPct: 2.20, avgScored: 0.40, h2hFhPct: 0.80 },
          SH05: { bias: -1.0, shPct: 2.30, avgConceded: 0.45, h2hShPct: 0.75 },
          HOME_WIN: { bias: -0.8, avgScored: 1.1, avgConceded: -0.9, cleanSheetPct: 0.8 }
        };
      }

      getWeights() { return this.weights; }

      // Adjust weights online based on self-audit errors
      learnFromAudit(auditRecord) {
        const lr = 0.02; // Learning rate
        const error = auditRecord.actualSuccess ? (1 - auditRecord.probability / 100) : (0 - auditRecord.probability / 100);
        
        if (this.weights[auditRecord.market]) {
          for (let key in this.weights[auditRecord.market]) {
            if (key !== 'bias') {
              this.weights[auditRecord.market][key] += lr * error;
            }
          }
        }
      }
    }

    // =========================================================================
    // MODULE 6: PREDICTION ENGINE & CONFIDENCE CLASSIFIER
    // =========================================================================
    class PredictionEngine {
      constructor(mlEngine) {
        this.mlEngine = mlEngine;
      }

      sigmoid(z) {
        return 1 / (1 + Math.exp(-z));
      }

      classifyConfidence(prob) {
        if (prob >= 78 || prob <= 22) return { label: 'Very High', colorClass: 'badge-veryhigh' };
        if (prob >= 68 || prob <= 32) return { label: 'High', colorClass: 'badge-high' };
        if (prob >= 58 || prob <= 42) return { label: 'Medium', colorClass: 'badge-medium' };
        if (prob >= 50 || prob <= 50) return { label: 'Low', colorClass: 'badge-low' };
        return { label: 'Very Low', colorClass: 'badge-verylow' };
      }

      predict(homeStats, awayStats, h2hStats) {
        const weights = this.mlEngine.getWeights();

        // Vector Aggregations
        const avgScored = (homeStats.avgScored + awayStats.avgScored) / 2;
        const avgConceded = (homeStats.avgConceded + awayStats.avgConceded) / 2;
        const o25Pct = (homeStats.o25Pct + awayStats.o25Pct) / 2;
        const bttsPct = (homeStats.bttsPct + awayStats.bttsPct) / 2;
        const fhPct = (homeStats.fhPct + awayStats.fhPct) / 2;
        const shPct = (homeStats.shPct + awayStats.shPct) / 2;
        const cleanSheetPct = (homeStats.cleanSheetPct + awayStats.cleanSheetPct) / 2;
        const failedToScorePct = (homeStats.failedToScorePct + awayStats.failedToScorePct) / 2;

        // Model 1: Over 2.5
        const zO25 = weights.O25.bias + (avgScored * weights.O25.avgScored) + (avgConceded * weights.O25.avgConceded) + 
                     (o25Pct * weights.O25.o25Pct) + (cleanSheetPct * weights.O25.cleanSheetPct) + (h2hStats.o25Pct * weights.O25.h2hO25Pct);
        const probO25 = Math.round(this.sigmoid(zO25) * 100);

        // Model 2: BTTS
        const zBTTS = weights.BTTS.bias + (bttsPct * weights.BTTS.bttsPct) + (cleanSheetPct * weights.BTTS.cleanSheetPct) + 
                      (failedToScorePct * weights.BTTS.failedToScorePct) + (h2hStats.bttsPct * weights.BTTS.h2hBttsPct);
        const probBTTS = Math.round(this.sigmoid(zBTTS) * 100);

        // Model 3: First Half Goal
        const zFH = weights.FH05.bias + (fhPct * weights.FH05.fhPct) + (avgScored * weights.FH05.avgScored) + (h2hStats.fhPct * weights.FH05.h2hFhPct);
        const probFH = Math.round(this.sigmoid(zFH) * 100);

        // Model 4: Second Half Goal
        const zSH = weights.SH05.bias + (shPct * weights.SH05.shPct) + (avgConceded * weights.SH05.avgConceded) + (h2hStats.shPct * weights.SH05.h2hShPct);
        const probSH = Math.round(this.sigmoid(zSH) * 100);

        // Home Win Probability
        const zHW = weights.HOME_WIN.bias + (homeStats.avgScored * weights.HOME_WIN.avgScored) - (homeStats.avgConceded * weights.HOME_WIN.avgConceded);
        const probHW = Math.round(this.sigmoid(zHW) * 100);

        return {
          o25: { prob: probO25, conf: this.classifyConfidence(probO25) },
          btts: { prob: probBTTS, conf: this.classifyConfidence(probBTTS) },
          fh05: { prob: probFH, conf: this.classifyConfidence(probFH) },
          sh05: { prob: probSH, conf: this.classifyConfidence(probSH) },
          homeWin: { prob: probHW, conf: this.classifyConfidence(probHW) }
        };
      }
    }

    // =========================================================================
    // MODULE 7: SELF-AUDIT & LEARNING ENGINE
    // =========================================================================
    class SelfAuditEngine {
      constructor(storageEngine, mlEngine) {
        this.storage = storageEngine;
        this.mlEngine = mlEngine;
      }

      async auditFixture(fixture, prediction) {
        if (fixture.fixture.status.short !== 'FT') return;

        const hG = fixture.goals.home ?? 0;
        const aG = fixture.goals.away ?? 0;
        const totalG = hG + aG;

        const o25Actual = totalG >= 3;
        const auditRecord = {
          fixtureId: fixture.fixture.id,
          teams: `${fixture.teams.home.name} vs ${fixture.teams.away.name}`,
          market: 'O25',
          probability: prediction.o25.prob,
          confidence: prediction.o25.conf.label,
          actualResult: `${hG}-${aG}`,
          actualSuccess: o25Actual,
          auditDate: new Date().toISOString()
        };

        await this.storage.saveAudit(auditRecord);
        this.mlEngine.learnFromAudit(auditRecord);
      }

      async calculateMetrics() {
        const audits = await this.storage.getAllAudits();
        if (audits.length === 0) return { total: 0, strikeRate: '0%', highConfAcc: '0%' };

        const total = audits.length;
        const hits = audits.filter(a => a.actualSuccess).length;
        const highConfAudits = audits.filter(a => a.confidence === 'Very High' || a.confidence === 'High');
        const highConfHits = highConfAudits.filter(a => a.actualSuccess).length;

        return {
          total: total,
          strikeRate: `${Math.round((hits / total) * 100)}%`,
          highConfAcc: highConfAudits.length > 0 ? `${Math.round((highConfHits / highConfAudits.length) * 100)}%` : '0%',
          audits: audits
        };
      }
    }

    // =========================================================================
    // MODULE 8: APPLICATION CONTROLLER & UI MANAGER
    // =========================================================================
    class AppController {
      constructor() {
        this.storage = new StorageEngine();
        this.cache = new CacheManager(this.storage);
        this.api = new APIEngine();
        this.data = new DataEngine(this.api, this.cache);
        this.ml = new MLEngine();
        this.prediction = new PredictionEngine(this.ml);
        this.audit = new SelfAuditEngine(this.storage, this.ml);

        this.fixtures = [];
        this.predictions = {};
      }

      async init() {
        await this.storage.init();
        document.getElementById('apiKeyInput').value = this.api.apiKey;

        this.bindEvents();
        this.renderWeights();

        const cachedSlate = await this.storage.getCache('daily_slate');
        if (cachedSlate) {
          this.fixtures = cachedSlate;
          this.renderFixtures();
        }
        await this.updateMetrics();
      }

      bindEvents() {
        document.getElementById('saveKeyBtn').addEventListener('click', () => {
          const key = document.getElementById('apiKeyInput').value.trim();
          if (key) {
            this.api.setApiKey(key);
            alert('API Key Saved Successfully');
          }
        });

        document.getElementById('syncSlateBtn').addEventListener('click', () => this.syncDailySlate());
        document.getElementById('batchScanBtn').addEventListener('click', () => this.scanAllFixtures());
      }

      async syncDailySlate() {
        const today = new Intl.DateTimeFormat('en-CA', { timeZone: 'Europe/Dublin' }).format(new Date());
        try {
          const rawFixtures = await this.api.fetchFromAPI(`fixtures?date=${today}&timezone=Europe/Dublin`);
          this.fixtures = rawFixtures;
          await this.storage.setCache('daily_slate', this.fixtures, 6 * 60 * 60 * 1000);
          this.renderFixtures();
        } catch (err) {
          alert(`Error syncing slate: ${err.message}`);
        }
      }

      async scanFixture(fixtureId) {
        const fix = this.fixtures.find(f => f.fixture.id === fixtureId);
        if (!fix) return;

        const [homeProfile, awayProfile, h2hProfile] = await Promise.all([
          this.data.buildHistoricalProfile(fix.teams.home.id),
          this.data.buildHistoricalProfile(fix.teams.away.id),
          this.data.buildH2HProfile(fix.teams.home.id, fix.teams.away.id)
        ]);

        const pred = this.prediction.predict(homeProfile, awayProfile, h2hProfile);
        this.predictions[fixtureId] = pred;

        if (fix.fixture.status.short === 'FT') {
          await this.audit.auditFixture(fix, pred);
          await this.updateMetrics();
        }

        this.renderFixtures();
        this.renderHighConfidence();
      }

      async scanAllFixtures() {
        for (let fix of this.fixtures) {
          await this.scanFixture(fix.fixture.id);
        }
      }

      async updateMetrics() {
        const metrics = await this.audit.calculateMetrics();
        document.getElementById('metricTotalAudited').innerText = metrics.total;
        document.getElementById('metricStrikeRate').innerText = metrics.strikeRate;
        document.getElementById('metricHighConfAcc').innerText = metrics.highConfAcc;

        if (metrics.audits) {
          const tbody = document.getElementById('auditTableBody');
          tbody.innerHTML = metrics.audits.map(a => `
            <tr class="hover:bg-gray-900/50">
              <td class="p-2 font-semibold text-white">${a.teams}</td>
              <td class="p-2">${a.market}</td>
              <td class="p-2 font-mono text-purple-400">${a.probability}%</td>
              <td class="p-2"><span class="px-1.5 py-0.5 rounded text-[10px] font-bold ${a.confidence === 'Very High' || a.confidence === 'High' ? 'badge-high' : 'badge-low'}">${a.confidence}</span></td>
              <td class="p-2 font-mono">${a.actualResult}</td>
              <td class="p-2 font-bold ${a.actualSuccess ? 'text-green-400' : 'text-red-400'}">${a.actualSuccess ? '✓ PASS' : '✗ FAIL'}</td>
            </tr>
          `).join('');
        }
      }

      renderFixtures() {
        const container = document.getElementById('fixturesList');
        if (this.fixtures.length === 0) {
          container.innerHTML = `<div class="text-center py-12 text-gray-500 text-sm">No fixtures available.</div>`;
          return;
        }

        container.innerHTML = this.fixtures.map(f => {
          const pred = this.predictions[f.fixture.id];
          return `
            <div class="bg-[#121620] border border-gray-800 rounded-lg p-3.5 flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-[10px] bg-gray-800 text-gray-400 px-1.5 py-0.5 rounded font-mono">${f.fixture.status.short}</span>
                  <span class="text-[10px] text-gray-500">${f.league.country} - ${f.league.name}</span>
                </div>
                <h3 class="text-sm font-bold text-white">${f.teams.home.name} <span class="text-gray-500 font-normal">v</span> ${f.teams.away.name}</h3>
              </div>

              ${pred ? `
                <div class="flex items-center gap-2 flex-wrap">
                  <div class="text-center bg-gray-950 p-2 rounded border border-gray-800 min-w-[70px]">
                    <span class="text-[9px] text-gray-400 block uppercase font-semibold">Over 2.5</span>
                    <span class="text-xs font-bold text-purple-400 font-mono">${pred.o25.prob}%</span>
                    <span class="block text-[8px] font-bold px-1 rounded mt-0.5 ${pred.o25.conf.colorClass}">${pred.o25.conf.label}</span>
                  </div>
                  <div class="text-center bg-gray-950 p-2 rounded border border-gray-800 min-w-[70px]">
                    <span class="text-[9px] text-gray-400 block uppercase font-semibold">BTTS</span>
                    <span class="text-xs font-bold text-emerald-400 font-mono">${pred.btts.prob}%</span>
                    <span class="block text-[8px] font-bold px-1 rounded mt-0.5 ${pred.btts.conf.colorClass}">${pred.btts.conf.label}</span>
                  </div>
                </div>
              ` : `
                <button onclick="window.app.scanFixture(${f.fixture.id})" class="bg-gray-800 hover:bg-gray-700 text-gray-300 text-xs px-3 py-1.5 rounded transition font-medium">Scan Match</button>
              `}
            </div>
          `;
        }).join('');
      }

      renderHighConfidence() {
        const container = document.getElementById('highConfList');
        const highConfFixtures = [];

        for (let f of this.fixtures) {
          const pred = this.predictions[f.fixture.id];
          if (pred && (pred.o25.conf.label === 'Very High' || pred.o25.conf.label === 'High' || pred.btts.conf.label === 'Very High')) {
            highConfFixtures.push({ fixture: f, pred: pred });
          }
        }

        if (highConfFixtures.length === 0) {
          container.innerHTML = `<div class="text-center py-12 text-gray-500 text-sm">No high confidence signals generated yet.</div>`;
          return;
        }

        container.innerHTML = highConfFixtures.map(item => `
          <div class="bg-[#121620] border border-purple-500/40 rounded-lg p-3.5 flex items-center justify-between">
            <div>
              <span class="text-[10px] text-purple-400 font-bold uppercase tracking-wider block">High Confidence Signal</span>
              <h3 class="text-sm font-bold text-white">${item.fixture.teams.home.name} vs ${item.fixture.teams.away.name}</h3>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs font-mono font-bold text-green-400">O2.5 Prob: ${item.pred.o25.prob}%</span>
              <span class="text-[10px] px-2 py-0.5 rounded font-bold ${item.pred.o25.conf.colorClass}">${item.pred.o25.conf.label}</span>
            </div>
          </div>
        `).join('');
      }

      renderWeights() {
        document.getElementById('modelWeightsDisplay').innerText = JSON.stringify(this.ml.getWeights(), null, 2);
      }
    }

    // Initialize Application Logic on Window
    window.addEventListener('DOMContentLoaded', async () => {
      window.app = new AppController();
      await window.app.init();
    });

    // View Navigation Control
    window.switchView = function(viewName) {
      ['fixtures', 'highconf', 'accuracy', 'performance'].forEach(v => {
        document.getElementById(`view-${v}`).classList.add('hidden');
        document.getElementById(`tab-${v}`).classList.remove('bg-purple-600', 'text-white');
        document.getElementById(`tab-${v}`).classList.add('bg-gray-800', 'text-gray-400');
      });

      document.getElementById(`view-${viewName}`).classList.remove('hidden');
      document.getElementById(`tab-${viewName}`).classList.add('bg-purple-600', 'text-white');
      document.getElementById(`tab-${viewName}`).classList.remove('bg-gray-800', 'text-gray-400');
    };
  </script>
</body>
</html>
